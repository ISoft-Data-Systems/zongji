{
  "name": "@isoftdata/zongji",
  "version": "2.0.0",
  "description": "A mysql binlog listener running on Node.js",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run test:5.7",
    "test:no-docker": "node --test --test-concurrency=1 \"test/*.js\"",
    "test:5.7": "docker compose up -d --wait mysql57 && node --test --test-concurrency=1 \"test/*.js\"",
    "test:8.3": "docker compose up -d --wait mysql83 && node --test --test-concurrency=1 \"test/*.js\"",
    "test:8.4": "docker compose up -d --wait mysql84 && node --test --test-concurrency=1 \"test/*.js\"",
    "test:all": "npm run test:5.7 && npm run test:8.3 && npm run test:8.4",
    "test:down": "docker compose down -v",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ISoft-Data-Systems/zongji"
  },
  "keywords": [
    "mysql",
    "binlog"
  ],
  "author": "Nevill <nevill.dutt@gmail.com>",
  "contributors": [
    "numtel <ben@latenightsketches.com> (https://github.com/numtel)",
    "rfanth <rfa@rfanth.com> (https://github.com/rfanth)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ISoft-Data-Systems/zongji/issues"
  },
  "homepage": "https://github.com/ISoft-Data-Systems/zongji",
  "engines": {
    "node": ">=22.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0"
  },
  "overrides": {
    "form-data": "^2.5.4"
  },
  "dependencies": {
    "@vlasky/mysql": "^2.18.7",
    "big-integer": "1.6.48",
    "iconv-lite": "0.5.1"
  }
}
